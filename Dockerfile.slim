# Image SERVICES-ONLY: Typesense + MCP server, KHONG kem du lieu.
# Du lieu import sau khi deploy (xem DEPLOY.md), luu trong volume /data.
FROM python:3.12-slim-bookworm

ENV PYTHONUNBUFFERED=1 PIP_NO_CACHE_DIR=1

RUN apt-get update \
    && apt-get install -y --no-install-recommends curl ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements.txt .
RUN pip install -r requirements.txt

COPY bin/typesense-server /usr/local/bin/typesense-server
RUN chmod +x /usr/local/bin/typesense-server

COPY legal_search/ /app/legal_search/
COPY docker/entrypoint.sh /app/entrypoint.sh
RUN sed -i 's/\r$//' /app/entrypoint.sh && chmod +x /app/entrypoint.sh && mkdir -p /data

# Cau hinh mac dinh (KHONG chua secret). EMBED_API_KEY truyen luc `docker run -e ...`.
ENV TYPESENSE_HOST=localhost \
    TYPESENSE_PORT=8108 \
    TYPESENSE_COLLECTION=legal_mainstream \
    TYPESENSE_API_KEY=poc_legal_search_2026 \
    EMBED_BASE_URL=https://proxy.cyberbot.vn/v1 \
    EMBED_MODEL=Qwen/Qwen3-Embedding-8B \
    EMBED_DIM=4096 \
    EMBED_BATCH_SIZE=16 \
    RERANK_MODEL=Qwen/Qwen3-Reranker-4B \
    RERANK_ENABLE=true \
    SEARCH_ALPHA=0.7 \
    SUBCHUNK_CHAR_THRESHOLD=4000 \
    MCP_HOST=0.0.0.0 \
    MCP_PORT=8000

VOLUME /data
EXPOSE 8000

# Chi check MCP: MCP chi len SAU khi Typesense san sang -> MCP up <=> he thong ready.
# KHONG curl Typesense trong luc load (Typesense 29 co the segfault khi nhan request luc load).
HEALTHCHECK --interval=15s --timeout=5s --start-period=600s --retries=5 \
  CMD curl -s http://localhost:8000/mcp >/dev/null || exit 1

ENTRYPOINT ["/app/entrypoint.sh"]
